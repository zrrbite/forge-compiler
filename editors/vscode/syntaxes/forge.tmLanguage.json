{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Forge",
  "scopeName": "source.forge",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#constants" },
    { "include": "#numbers" },
    { "include": "#operators" },
    { "include": "#functions" },
    { "include": "#variables" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.forge",
          "match": "//.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.forge",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.forge",
              "match": "\\\\[nrt\\\\\"{}0]"
            },
            {
              "name": "meta.interpolation.forge",
              "begin": "\\{",
              "end": "\\}",
              "beginCaptures": {
                "0": { "name": "punctuation.section.interpolation.begin.forge" }
              },
              "endCaptures": {
                "0": { "name": "punctuation.section.interpolation.end.forge" }
              },
              "patterns": [
                { "include": "source.forge" }
              ]
            }
          ]
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.forge",
          "match": "\\b(if|else|while|for|in|match|return|break|continue|spawn)\\b"
        },
        {
          "name": "keyword.declaration.forge",
          "match": "\\b(fn|let|mut|struct|impl|trait|enum|use|pub|mod|comptime|where)\\b"
        },
        {
          "name": "variable.language.forge",
          "match": "\\b(self|Self)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.primitive.forge",
          "match": "\\b(i8|i16|i32|i64|i128|u8|u16|u32|u64|u128|f32|f64|bool|str|usize|isize)\\b"
        },
        {
          "name": "entity.name.type.forge",
          "match": "\\b[A-Z][A-Za-z0-9_]*\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.forge",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "constant.language.forge",
          "match": "\\b(None)\\b"
        },
        {
          "name": "constant.language.math.forge",
          "match": "\\b(PI|E)\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.forge",
          "match": "\\b[0-9]+\\.[0-9]+\\b"
        },
        {
          "name": "constant.numeric.integer.forge",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.arrow.forge",
          "match": "->|=>"
        },
        {
          "name": "keyword.operator.comparison.forge",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.logical.forge",
          "match": "&&|\\|\\||!"
        },
        {
          "name": "keyword.operator.assignment.forge",
          "match": "\\+=|-=|\\*=|/=|%=|="
        },
        {
          "name": "keyword.operator.range.forge",
          "match": "\\.\\.|\\.\\.="
        },
        {
          "name": "keyword.operator.error-propagation.forge",
          "match": "\\?"
        },
        {
          "name": "keyword.operator.at.forge",
          "match": "@"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.forge",
          "match": "\\b([a-z_][a-zA-Z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "entity.name.function.forge" }
          }
        }
      ]
    },
    "variables": {
      "patterns": [
        {
          "name": "variable.other.forge",
          "match": "\\b[a-z_][a-zA-Z0-9_]*\\b"
        }
      ]
    }
  }
}
