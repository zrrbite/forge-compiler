// Test codegen with vec2.fg (structs, methods, operator overloading)
use lexer
use ast
use parser
use codegen

fn main() {
    let source = File.read("tests/samples/vec2.fg").unwrap()
    let raw_tokens = tokenize(source)
    let tokens = collapse_newlines(raw_tokens)

    print("Lexed {tokens.len()} tokens")

    let mut p = Parser.new(tokens)
    let items = parse_program(p)

    print("Parsed {items.len()} items:")
    for item in items {
        print("  {item.describe()}")
    }

    print("")
    print("=== Generated C code ===")
    print("")

    let c_code = generate(items)
    print(c_code)
}
