// Status: Requires stdlib (net, json, db), use/imports, and ? propagation.

struct Route {
    method: str,
    path: str,
}

impl Route {
    fn new(method: str, path: str) -> Route {
        Route { method, path }
    }

    fn describe(self) -> str {
        "{self.method} {self.path}"
    }
}

fn main() {
    print("http_server.fg: placeholder")
    print("Full HTTP server requires stdlib and imports")
    print("")

    // Show the intended routing structure
    print("=== Planned routes ===")
    let r1 = Route.new("GET", "/users")
    let r2 = Route.new("GET", "/users/:id")
    let r3 = Route.new("POST", "/users")
    let r4 = Route.new("PUT", "/users/:id")
    let r5 = Route.new("DELETE", "/users/:id")
    let routes = [r1, r2, r3, r4, r5]

    for route in routes {
        print("  {route.describe()}")
    }

    print("")
    print("When stdlib lands, this will be a real HTTP server")
}
